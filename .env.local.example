# Same Supabase project the main CanoryAI app uses — this admin panel
# reads/writes the same organizations, user_roles, and shipments tables.
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# SERVER-ONLY, never exposed to the browser. Supabase Dashboard ->
# Project Settings -> API -> service_role key ("secret", not "anon").
# This key bypasses Row Level Security entirely and can create/delete
# any user — treat it like a root password. Never commit it, never put
# it in a NEXT_PUBLIC_ variable.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# This admin panel's own deployed URL (Supabase's invite email link
# points back here). Use http://localhost:3001 for local dev.
NEXT_PUBLIC_APP_URL=https://admin.canoryai.example.com

# The main CanoryAI app's login page — where a customer is sent after
# they finish setting their password here.
NEXT_PUBLIC_CUSTOMER_APP_LOGIN_URL=https://app.canoryai.example.com/login

# For emailing customers when staff reply to their contact ticket. Same
# Resend account as the main app — optional; replies still save without
# it, the customer just won't get an email nudge.
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_ADDRESS=CanoryAI <notifications@canoryai.example.com>

# The main app's public ticket-tracking page, linked from reply emails.
NEXT_PUBLIC_CUSTOMER_APP_TICKET_TRACKING_URL=https://app.canoryai.example.com/contact/track
